# ── App ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── MongoDB ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/socialescrow

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ── Bcrypt ───────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Email (Nodemailer) ───────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=SocialEscrow <noreply@socialescrow.co.ke>

# ── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── M-Pesa Daraja ────────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_B2C_INITIATOR=your_initiator
MPESA_B2C_SECURITY_CREDENTIAL=your_credential
MPESA_CALLBACK_URL=https://your-railway-url.railway.app/api/mpesa/callback
MPESA_B2C_RESULT_URL=https://your-railway-url.railway.app/api/mpesa/b2c/result
MPESA_B2C_TIMEOUT_URL=https://your-railway-url.railway.app/api/mpesa/b2c/timeout

# ── Vault Encryption ─────────────────────────────────
VAULT_ENCRYPTION_KEY=32_char_hex_key_change_this_now_
VAULT_ENCRYPTION_IV=16_char_iv_here_

# ── Platform ─────────────────────────────────────────
PLATFORM_FEE_PERCENT=6
PAYMENT_WINDOW_MINUTES=30
CONFIRM_WINDOW_HOURS=24
